# ─── Backend ──────────────────────────────────────────────
DEBUG=true
FRONTEND_URL=http://localhost:5173
JWT_SECRET=dev-only-please-change-this-to-something-long-and-random
JWT_EXPIRES_MINUTES=1440
RATE_LIMIT_PER_MIN=120

# ─── Database (SQLite by default; swap to Postgres for prod) ───
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# ─── Scan engine ─────────────────────────────────────────
SCAN_TIMEOUT_SECONDS=600
SCAN_REQUEST_DELAY_MS=200
SCAN_USER_AGENT=Sentinel-Scanner/0.1 (+https://sentinel.local)

# Set to true to require domain verification before any scan can be enqueued.
REQUIRE_VERIFIED_TARGET=false

# ─── Reports ─────────────────────────────────────────────
REPORTS_DIR=./reports

# ─── Frontend (read by Vite at build time) ───────────────
VITE_API_URL=http://localhost:8000
